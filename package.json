    "@sentry/nextjs": "^10.36.0",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/dom": "^10.4.1",
    "autoprefixer": "^10.4.24",
    "baseline-browser-mapping": "^2.10.0",
