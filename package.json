{
  "name": "blog-ai-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @blog-ai/web",
    "build": "npm run build --workspace @blog-ai/web",
    "start": "npm run start --workspace @blog-ai/web",
    "lint": "npm run lint --workspace @blog-ai/web",
    "lint:fix": "npm run lint:fix --workspace @blog-ai/web",
    "type-check": "npm run type-check --workspace @blog-ai/web",
    "db:migrate": "node scripts/migrate_db.mjs",
    "analyze": "npm run analyze --workspace @blog-ai/web",
    "test": "npm run test --workspace @blog-ai/web",
    "test:run": "npm run test:run --workspace @blog-ai/web",
    "test:coverage": "npm run test:coverage --workspace @blog-ai/web",
    "test:e2e": "npm run test:e2e --workspace @blog-ai/web",
    "test:e2e:coverage": "npm run test:e2e:coverage --workspace @blog-ai/web",
    "test:e2e:ui": "npm run test:e2e:ui --workspace @blog-ai/web",
    "test:e2e:headed": "npm run test:e2e:headed --workspace @blog-ai/web",
    "test:api:smoke": "pytest apps/api/tests/test_ci_smoke.py apps/api/tests/test_feature_smoke.py -q",
    "test:api:blocking": "pytest apps/api/tests/test_feature_smoke.py apps/api/tests/test_routes_health.py -q",
    "test:api:full": "pytest apps/api/tests -q"
  },
  "overrides": {
    "glob": "^13.0.6",
    "minimatch": "^10.2.3",
    "rollup": "^4.59.0"
  }
}
