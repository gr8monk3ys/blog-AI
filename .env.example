# API Keys (Required)
# Get your OpenAI API key at: https://platform.openai.com/api-keys
# Example format: OPENAI_API_KEY=sk-proj-abc123def456...
OPENAI_API_KEY=

# Optional API Keys
# Anthropic Claude API key (for alternative LLM provider)
# Get your key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
# SERP_API_KEY=  # For search functionality (not yet implemented)

# Model Configuration
DEFAULT_MODEL=gpt-4
TEMPERATURE=0.9
# MAX_TOKENS=  # Optional, leave blank for no limit

# Blog Generation Settings
BLOG_SECTIONS=3
BLOG_SUBTOPICS_MIN=2
BLOG_SUBTOPICS_MAX=3

# Book Generation Settings
BOOK_CHAPTERS=11
BOOK_TOPICS_PER_CHAPTER=4
BOOK_TARGET_WORDS_PER_TOPIC=2000

# Output Directories
BLOG_OUTPUT_DIR=content/blog
BOOK_OUTPUT_DIR=content/books

# API Rate Limiting
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=2.0
API_RETRY_BACKOFF=2.0

# Logging
LOG_LEVEL=INFO
VERBOSE=false

# Caching
CACHE_ENABLED=true
CACHE_TTL=3600  # Cache time-to-live in seconds (1 hour)
CACHE_MAX_SIZE=1000  # Maximum number of cached entries
